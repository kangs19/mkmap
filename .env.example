# Do not commit real keys.
APP_NAME=AgriDigitalTwin
APP_ENV=development

# DB: SQLite (development) or PostgreSQL (production)
DATABASE_URL=sqlite+aiosqlite:///./agri_twin.db
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/agri_twin

# Public API keys
DATA_GO_KR_API_KEY=
KOSIS_API_KEY=
KAMIS_API_KEY=
KMA_API_KEY=
ECOS_API_KEY=

# Security
API_SECRET_KEY=change-this-secret-key
JWT_SECRET_KEY=change-this-jwt-secret

# WordPress
WORDPRESS_BASE_URL=

# Rate limit defaults
DEFAULT_RATE_LIMIT_PER_DAY=100

# KAMIS price API
KAMIS_PRICE_BASE_URL=https://www.kamis.or.kr/service/price/xml.do
KAMIS_PRICE_ACTION=periodProductList
KAMIS_CERT_ID=
KAMIS_RETURN_TYPE_VALUE=json
KAMIS_PRODUCT_CLASSES=01,02

AT_REGIONAL_PRICE_BASE_URL=http://apis.data.go.kr/B552845/perRegion
AT_REGIONAL_PRICE_OPERATION=price
AT_REGIONAL_PRICE_DATE_PARAM=examinDe
AT_REGIONAL_PRICE_ITEM_PARAM=item_code
AT_REGIONAL_PRICE_TYPE=json
AT_REGIONAL_PRICE_DATA_TYPE=JSON

AT_MARKET_SETTLEMENT_BASE_URL=
AT_MARKET_SETTLEMENT_OPERATION=
AT_MARKET_SETTLEMENT_DATE_PARAM=date
AT_MARKET_SETTLEMENT_ITEM_PARAM=item_code
AT_MARKET_SETTLEMENT_TYPE=json

KOSIS_PRODUCTION_BASE_URL=https://kosis.kr/openapi/Param/statisticsParameterData.do
KOSIS_PRODUCTION_ORG_ID=101
KOSIS_PRODUCTION_TBL_ID=
KOSIS_PRODUCTION_PERIOD_TYPE=Y
KOSIS_PRODUCTION_ITEM_PARAM=itmId
KOSIS_PRODUCTION_YEAR_PARAM=startPrdDe

KMA_CROP_WEATHER_BASE_URL=http://apis.data.go.kr/1360000/FmlandWthrInfoService
KMA_CROP_WEATHER_OPERATION=getDayStatistics
KMA_CROP_WEATHER_START_DATE_PARAM=ST_YMD
KMA_CROP_WEATHER_END_DATE_PARAM=ED_YMD
KMA_CROP_WEATHER_AREA_PARAM=AREA_ID
KMA_CROP_WEATHER_CROP_PARAM=PA_CROP_SPE_ID

RDA_AGRI_WEATHER_BASE_URL=
RDA_AGRI_WEATHER_OPERATION=
RDA_AGRI_WEATHER_ITEM_PARAM=item_code
RDA_AGRI_WEATHER_DATE_PARAM=date

KMA_WEATHER_ALERT_BASE_URL=http://apis.data.go.kr/1360000/WthrWrnInfoService
KMA_WEATHER_ALERT_OPERATION=getWthrWrnList
KMA_WEATHER_ALERT_FROM_PARAM=fromTmFc
KMA_WEATHER_ALERT_TO_PARAM=toTmFc
KMA_WEATHER_ALERT_STN_PARAM=stnId

KMA_IMPACT_FORECAST_BASE_URL=http://apis.data.go.kr/1360000/ImpactInfoServiceV2
KMA_IMPACT_FORECAST_OPERATION=getHWImpactValueV2
KMA_IMPACT_FORECAST_DATE_PARAM=tmFc

KMA_TYPHOON_BASE_URL=http://apis.data.go.kr/1360000/TyphoonInfoService
KMA_TYPHOON_OPERATION=getTyphoonInfoList
KMA_TYPHOON_LIST_OPERATION=getTyphoonInfoList
KMA_TYPHOON_DATE_PARAM=tmFc

KMA_MIDTERM_FORECAST_BASE_URL=http://apis.data.go.kr/1360000/MidFcstInfoService
KMA_MIDTERM_FORECAST_OPERATION=getMidFcst
KMA_MIDTERM_FORECAST_DATE_PARAM=tmFc
KMA_MIDTERM_FORECAST_STN_PARAM=stnId

KMA_SATELLITE_BASE_URL=
KMA_SATELLITE_OPERATION=
KMA_SATELLITE_DATE_PARAM=date

KMA_WEATHER_CHART_BASE_URL=
KMA_WEATHER_CHART_OPERATION=
KMA_WEATHER_CHART_DATE_PARAM=date
